{
  "name": "incident-commander-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10",
      "vite": "^6.4.3"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @incident-commander/web dev",

# Demo mode is the default and requires NO external credentials.
DEMO_MODE=true

# Protects POST /api/v1/incidents/reset-demo. Local default only; override in
# any shared environment.
DEMO_ADMIN_KEY=demo-admin-key

API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend -> API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional: live adapters ----------------------------------------------
# Demo mode always uses deterministic fixtures even when credentials exist.
# Full live application startup remains disabled until live evidence sources
# are configured; the OpenAI investigation gateway can be smoke-tested alone.
# INVESTIGATION_ENGINE=openai
# Build Week live target. Keep DEMO_MODE=true for the credential-free fixture path.
# INVESTIGATION_MODEL=gpt-5.6
# OPENAI_TIMEOUT_SECONDS=30
# OPENAI_API_KEY=
# GITHUB_TOKEN=

# --- Local persistence ----------------------------------------------------
# Docker Compose supplies container hostnames. Use these values for local
# API/worker processes started outside Compose.
# DATABASE_URL=postgresql+psycopg://incident:incident-local@localhost:5432/incident_commander
# REDIS_URL=redis://localhost:6379/0

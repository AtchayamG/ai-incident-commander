# Demo mode is the default and requires NO external credentials.
DEMO_MODE=true

# Protects POST /api/v1/incidents/reset-demo. Local default only; override in
# any shared environment.
DEMO_ADMIN_KEY=demo-admin-key

API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Frontend -> API base URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Optional: live mode (M4-M7, not implemented in M0) ------------------
# The API refuses to start with DEMO_MODE=false until live providers exist.
# OPENAI_API_KEY=
# GITHUB_TOKEN=

# --- Optional: persistence (M1+, compose profile "persistence") ----------
# DATABASE_URL=postgresql://incident:incident-local@localhost:5432/incident_commander
# REDIS_URL=redis://localhost:6379/0
